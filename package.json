{
  "name": "@tkorkmaz/toolgate",
  "version": "0.1.0-alpha.1",
  "description": "Billing-aware execution SDK for paid MCP tools — graceful fallback, post-execution metering, and programmable billing logic.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test src/__tests__/paidTool.test.mjs src/__tests__/mcp-adapter.test.mjs src/__tests__/stripe.test.mjs src/__tests__/webhook-handler.test.mjs src/__tests__/db-ledger.test.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "payments",
    "billing",
    "usage-billing",
    "monetization",
    "ai-tools",
    "stripe",
    "prepaid",
    "agent",
    "llm",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tkorkmazeth/toolgate"
  },
  "homepage": "https://toolgate.dev",
  "bugs": {
    "url": "https://github.com/tkorkmazeth/toolgate/issues"
  },
  "peerDependencies": {
    "stripe": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "stripe": {
      "optional": true
    }
  },
  "devDependencies": {
    "stripe": "^17.7.0",
    "typescript": "^5.4.0"
  },
  "author": "Toolgate <hello@toolgate.dev>"
}
