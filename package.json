{
  "name": "@niceberglabs/tollgate",
  "version": "0.3.0-beta.0",
  "description": "Paid-action runtime for MCP tools. Execution, billing, recovery, and idempotency for paid AI agent tool calls.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "LICENSE",
    "examples/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "package:dry-run": "npm pack --dry-run",
    "example:local": "npm run build && node examples/local-first-runtime/scenario.mjs",
    "test:sdk": "npm run build && node --test --test-force-exit src/__tests__/firecrawl-integration.test.mjs src/__tests__/local-first.test.mjs",
    "test:scenarios": "npm run scenario:ledger && npm run scenario:mcp-e2e",
    "scenario:ledger": "npm run build && node examples/mcp-ledger-recovery/scenario.mjs",
    "scenario:stripe": "npm run build && node integrations/stripe-test-mode/scenario.mjs",
    "scenario:firecrawl": "npm run build && node integrations/firecrawl-mcp-tollgate/scenario-fake.mjs",
    "scenario:firecrawl:fake": "npm run build && node integrations/firecrawl-mcp-tollgate/scenario-fake.mjs",
    "scenario:firecrawl:live": "npm run build && node integrations/firecrawl-mcp-tollgate/scenario-live.mjs",
    "scenario:mcp-e2e": "npm run build && node integrations/firecrawl-mcp-tollgate/scenario-mcp-e2e.mjs",
    "scenario:mpp": "npm run build && node examples/mcp-mpp-recovery/scenario.mjs",
    "scenario:x402": "npm run build && node examples/mcp-x402-experimental/scenario.mjs",
    "scenario:x402-testnet:challenge": "npm run build && node examples/x402-testnet-recovery/challenge.mjs",
    "scenario:x402-testnet:sign": "npm run build && node examples/x402-testnet-recovery/challenge.mjs | node examples/x402-testnet-recovery/sign-payload.mjs",
    "scenario:x402-testnet": "npm run build && node integrations/x402-testnet/scenario.mjs",
    "test": "npm run build && node --test --test-force-exit src/__tests__/paidTool.test.mjs src/__tests__/mcp-adapter.test.mjs src/__tests__/stripe.test.mjs src/__tests__/webhook-handler.test.mjs src/__tests__/db-ledger.test.mjs src/__tests__/rail-adapter.test.mjs src/__tests__/policy.test.mjs src/__tests__/protocol-compliance.test.mjs src/__tests__/idempotency.test.mjs src/__tests__/trace.test.mjs src/__tests__/firecrawl-integration.test.mjs src/__tests__/local-first.test.mjs",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "mcp",
    "payments",
    "billing",
    "usage-billing",
    "monetization",
    "ai-tools",
    "stripe",
    "prepaid",
    "agent",
    "llm",
    "model-context-protocol",
    "mpp",
    "x402",
    "rail-agnostic",
    "agentic-commerce"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niceberginc/tollgate.git"
  },
  "homepage": "https://main.tollgate.pages.dev",
  "bugs": {
    "url": "https://github.com/niceberginc/tollgate/issues"
  },
  "peerDependencies": {
    "@x402/core": ">=0.1.0",
    "mppx": ">=0.1.0",
    "stripe": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "stripe": {
      "optional": true
    },
    "mppx": {
      "optional": true
    },
    "@x402/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "stripe": "^17.7.0",
    "typescript": "^5.4.0",
    "viem": "^2.52.2",
    "zod": "^3.25.76"
  },
  "author": "Tollgate <hello@niceberglabs.com>"
}
