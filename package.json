{
  "name": "@tkorkmaz/toolgate",
  "version": "0.2.0-alpha.1",
  "description": "Paid action recovery & execution-control layer for AI agent tools — idempotent execution, failure recovery, graceful fallback, and rail-agnostic billing. Works with Stripe, MPP, and x402.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "scenario:ledger": "npm run build && node examples/mcp-ledger-recovery/scenario.mjs",
    "scenario:mpp": "npm run build && node examples/mcp-mpp-recovery/scenario.mjs",
    "scenario:x402": "npm run build && node examples/mcp-x402-experimental/scenario.mjs",
    "test": "node --test src/__tests__/paidTool.test.mjs src/__tests__/mcp-adapter.test.mjs src/__tests__/stripe.test.mjs src/__tests__/webhook-handler.test.mjs src/__tests__/db-ledger.test.mjs src/__tests__/rail-adapter.test.mjs src/__tests__/policy.test.mjs src/__tests__/protocol-compliance.test.mjs src/__tests__/idempotency.test.mjs src/__tests__/trace.test.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "payments",
    "billing",
    "usage-billing",
    "monetization",
    "ai-tools",
    "stripe",
    "prepaid",
    "agent",
    "llm",
    "model-context-protocol",
    "mpp",
    "x402",
    "rail-agnostic",
    "agentic-commerce"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tkorkmazeth/toolgate"
  },
  "homepage": "https://toolgate.dev",
  "bugs": {
    "url": "https://github.com/tkorkmazeth/toolgate/issues"
  },
  "peerDependencies": {
    "stripe": ">=14.0.0",
    "mppx": ">=0.1.0",
    "@x402/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "stripe": {
      "optional": true
    },
    "mppx": {
      "optional": true
    },
    "@x402/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "stripe": "^17.7.0",
    "typescript": "^5.4.0"
  },
  "author": "Toolgate <hello@toolgate.dev>"
}
